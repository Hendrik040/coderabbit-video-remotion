{
  "name": "coderabbit-video-intro",
  "version": "1.0.0",
  "description": "CodeRabbit YouTube intro video using Remotion",
  "main": "index.js",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts CodeRabbitIntro out/intro.mp4",
    "build:intro": "remotion render src/index.ts CodeRabbitIntro out/intro.mp4",
    "build:impact": "remotion render src/index.ts ImpactSlicerViz out/impact-slicer.mp4",
    "build:ast": "remotion render src/index.ts ASTWalkViz out/ast-walk.mp4",
    "build:compare": "remotion render src/index.ts ReviewSystemsCompare out/review-compare.mp4",
    "build:quote": "remotion render src/index.ts CustomerQuote out/customer-quote.mp4",
    "preview": "remotion preview src/index.ts"
  },
  "keywords": [
    "remotion",
    "video",
    "coderabbit",
    "intro"
  ],
  "author": "CodeRabbit",
  "license": "MIT",
  "dependencies": {
    "@remotion/bundler": "^4.0.409",
    "@remotion/cli": "^4.0.409",
    "@remotion/google-fonts": "^4.0.431",
    "@types/react": "^19.2.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remotion": "^4.0.409",
    "typescript": "^5.9.3"
  }
}
